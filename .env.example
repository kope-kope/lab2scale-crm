# Copy to .env and fill in. All VITE_* vars are exposed to the browser (public).

# OAuth client ID from the Google console (LAB-5). Public — embedded in the SPA.
VITE_GOOGLE_CLIENT_ID=
# Google Workspace domain allowed to sign in (the hd claim must match this).
VITE_ALLOWED_DOMAIN=lab-2-scale.com
# The shared Drive top-folder id holding Accounts/Contacts/Leads (LAB-6).
VITE_DRIVE_FOLDER_ID=
# Base URL of the API when it's hosted separately (Railway). Leave EMPTY for
# local dev (vite proxies /api) and the single-container build. In Vercel, set
# this to the Railway URL, e.g. https://lab2scale-crm-api.up.railway.app (no slash).
VITE_API_BASE_URL=

# NOTE: the OAuth *client secret* is deliberately not used here. The browser
# sign-in + Drive-read flow needs only the client ID. Keep the secret out of the repo.

# --- Server-side only (NOT VITE_ — never exposed to the browser) ---
# These live on the API host (Railway), never on Vercel.
# Anthropic API key for the AI contact finder (LAB-22). Requires the web-search
# tool enabled on the Anthropic org.
ANTHROPIC_API_KEY=
# Optional: override the Google domain the finder endpoint accepts (defaults to
# lab-2-scale.com).
# ALLOWED_DOMAIN=lab-2-scale.com
# Allowed browser origins for CORS when the frontend (Vercel) calls the API
# (Railway) cross-origin. Comma-separated; exact origins or a wildcard host.
# Leave empty for same-origin dev / single-container. Example:
# CORS_ORIGIN=https://lab2scale-crm.vercel.app,*.vercel.app
CORS_ORIGIN=
# Port is provided by Railway automatically (PORT); locally the API uses 8080.
